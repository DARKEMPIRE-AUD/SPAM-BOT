# Discord Bot Token
BOT_TOKEN=your_bot_token_here

# OAuth2 Configuration
# Get these from Discord Developer Portal: https://discord.com/developers/applications
BOT_CLIENT_ID=your_client_id_here
BOT_CLIENT_SECRET=your_client_secret_here

# OAuth2 Redirect URI (must match what you set in Discord Developer Portal)
OAUTH_REDIRECT_URI=http://localhost:8080/callback
